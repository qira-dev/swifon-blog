modules = ["nodejs-20", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=5000 pnpm --filter @workspace/qirahub run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 4200

[[ports]]
localPort = 23215
externalPort = 3000

[[ports]]
localPort = 23216
externalPort = 3003

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=5000 NODE_ENV=production node --enable-source-maps ./artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm --filter @workspace/qirahub run build && pnpm --filter @workspace/api-server run build"]
